# admin_utils (offline ingredient-parsing pipeline) configuration.
# Copy to `.env` in this same directory -- supabase_client.py looks for it here
# specifically and raises FileNotFoundError if it is missing.
#
# This pipeline is NOT part of the runtime app. It is run by hand to parse recipe
# ingredients into the grocery_items_per_recipe table. See README_WORKFLOW.md.

SUPABASE_URL=

# Unlike the runtime backend, this pipeline WRITES to the reference tables, which
# are read-only under RLS. Use the **service_role** key here. It bypasses RLS, so
# keep it out of the frontend, out of the runtime backend, and out of git.
SUPABASE_KEY=

# LLM access, used for ingredient parsing and correction validation.
# The scripts speak the OpenAI API shape; OPENAI_BASE_URL points them at
# OpenRouter by default.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
