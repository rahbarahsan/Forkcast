# Backend (FastAPI) configuration.
# Copy to `.env` in this directory and fill in the values from your own
# Supabase project: Dashboard -> Project Settings -> API.

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# The **anon / public** key -- not the service_role key.
#
# The runtime backend only ever reads public reference data, and Row Level
# Security (see supabase/migrations/) is what protects everything else. Using
# service_role here would bypass RLS entirely and defeat that. service_role
# belongs only in the offline admin_utils pipeline.
SUPABASE_KEY=
