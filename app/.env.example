# Frontend (Expo) configuration.
# Copy to `.env` in this directory and fill in your own values.
#
# Everything prefixed EXPO_PUBLIC_ is embedded into the JavaScript bundle and is
# therefore readable by anyone using the app. That is expected: the Supabase anon
# key is designed to be public, and Row Level Security is the actual security
# boundary. Never put a service_role key in this file.

# Where the grocery-list API lives.
# Local development: http://localhost:8000/api
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Supabase project URL, e.g. https://abcdefghijklmnop.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# The anon / public key from Project Settings -> API.
EXPO_PUBLIC_SUPABASE_ANON_KEY=
