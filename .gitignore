# Node modules - ignore in any directory
**/node_modules/
.buckd/
.bazel/
.pnp/
.pnp.js

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarnrc.yml

# Expo
.expo/
.expo-shared/

# TypeScript
*.tsbuildinfo

# macOS
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE
.vscode/
.idea/

# Testing
coverage/

# Environment files - ignore in any directory
**/.env
**/.env.*
# ...but the templates must be committed so others can set the project up.
!**/.env.example

# Ignore pipeline_config.json
backend/admin_utils/config/pipeline_config.json
backend/admin_utils/logs/
backend/admin_utils/csv/*
backend/admin_utils/cache/

# Python
# Ignore __pycache__ in any directory
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
*.egg-info/
.installed.cfg
*.egg

# Files ending with config
**/*config.*
**/*config
# Git cannot re-include a file whose parent directory is excluded, so the
# directory itself has to be un-ignored before the example files below take
# effect. (Without this line the negations silently do nothing.)
!backend/admin_utils/config/
!backend/admin_utils/config/pipeline_config_example.json
!backend/admin_utils/config/.env.example

# Build artifacts
dist/
build/
web-build/

# Metro
metro-cache/
